# ─── Production checklist ──────────────────────────────────────────────────
# Before deploying to production, MAKE SURE you set:
#   APP_ENV=production
#   APP_DEBUG=false           # leaking debug pages exposes secrets
#   LOG_LEVEL=warning         # or `error`
#   APP_KEY=<generated>       # `php artisan key:generate`
#   SESSION_ENCRYPT=true      # encrypt sessions at rest
#   SESSION_DOMAIN=<host>     # lock cookies to your domain
# Do NOT commit a populated .env to git.
# ───────────────────────────────────────────────────────────────────────────

APP_NAME=Inventorix
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=inventorix
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── Microsoft Entra ID (Azure AD) SSO ─────────────────────────────────────
# Set MS_LOGIN_ENABLED=true and fill the credentials to enable the
# "Login via Entra ID" button on the Filament login page.
MS_LOGIN_ENABLED=false
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REDIRECT_URI="${APP_URL}/auth/microsoft/callback"

# ─── Container runtime ─────────────────────────────────────────────────────
# RUN_MIGRATIONS controls whether `php artisan migrate --force` runs on
# container start. For single-replica deployments, `true` is convenient.
# For multi-replica deployments (k8s, swarm), set this to `false` on the
# app pods and run migrations as a one-shot job to avoid races.
RUN_MIGRATIONS=true
